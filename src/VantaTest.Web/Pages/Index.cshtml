@page
@model VantaTest.Web.Pages.IndexModel
@using VantaTest.Web.Menus
@using Volo.Abp.AspNetCore.Mvc.UI.Layout
@using Microsoft.AspNetCore.Mvc.Localization
@using VantaTest.Localization
@using Volo.Abp.Users
@inject IPageLayout PageLayout
@inject IHtmlLocalizer<VantaTestResource> L
@inject ICurrentUser CurrentUser

@section scripts {
    <abp-script src="/Pages/Index.js" />
}
@section styles {
    <abp-style src="/Pages/Index.css" />
}

<!-- MAIN -->

<main class="main-content flex-grow-1">
    <div class="p-0 mb-5" style="width: 100vw; max-width: 4000px; position: relative; left: 50%; transform: translateX(-50%);">
        <div id="header-carousel" class="carousel slide" data-bs-ride="carousel">
            <div class="carousel-inner">
                <div class="carousel-item active">
                    <img class="w-100" src="~/images/getting-started/food-burger2.jpg" alt="Image" style="max-height: 1150px; object-fit: cover;">
                    <div class="carousel-caption text-center d-flex flex-column align-items-center">

                        <div class="row align-items-center justify-content-center justify-content-lg-start">
                            <div class="col-10 text-center">
                                <h1 class="slider-title">Burger</h1>
                                <a href="" class="go-menu animated slideInDown">Menu<i class="fa fa-arrow-right ms-3"></i></a>
                            </div>
                            <div class="col-lg-5 d-none d-lg-flex animated zoomIn">
                                <img class="img-fluid" src="img/carousel-1.png" alt="">
                            </div>
                        </div>

                    </div>
                </div>
                <div class="carousel-item">
                    <img class="w-100" src="~/images/getting-started/food-pizza2.jpg" alt="Image" style="max-height: 1150px; object-fit: cover;">
                    <div class="carousel-caption text-center d-flex flex-column align-items-center">

                        <div class="row align-items-center justify-content-center justify-content-lg-start">
                            <div class="col-10 text-center">
                                <h1 class="slider-title">Pizza</h1>
                                <a href="" class="go-menu animated slideInDown">Menu<i class="fa fa-arrow-right ms-3"></i></a>
                            </div>
                            <div class="col-lg-5 d-none d-lg-flex animated zoomIn">
                                <img class="img-fluid" src="img/carousel-2.png" alt="">
                            </div>

                        </div>
                    </div>
                </div>
                <button class="carousel-control-prev" type="button" data-bs-target="#header-carousel"
                        data-bs-slide="prev">
                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Previous</span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#header-carousel"
                        data-bs-slide="next">
                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Next</span>
                </button>
            </div>
        </div>
    </div>
</main>
<!-- START THE FEATURETTES -->

<div class="container-fluid p-0 mt-5 full-width-breakout">
    @{
        int index = 0;
    }
    @foreach (var item in Model.Headers)
    {
        string textOrderClass = (index % 2 != 0) ? "order-md-2" : "";
        string textAlignClass = (index % 2 != 0) ? "text-start" : "text-end";
        string imageAlignClass = (index % 2 != 0) ? "ms-auto d-block" : "me-auto d-block";

        <hr class="featurette-divider m-0">

        <div class="row featurette align-items-center p-0 py-md-5 m-0">
            <div class="col-md-6 @textOrderClass @textAlignClass p-3 p-md-5">
                <h2 class="featurette-heading">@item.MainHeader</h2>
                <p class="lead">@item.Description</p>
            </div>
            <div class="col-md-6">
                <img src="@item.ImagePath"
                     class="bd-placeholder-img bd-placeholder-img-lg featurette-image img-fluid @imageAlignClass"
                     alt="Genişletilmiş Resim"
                     style="width: 80%; height: 450px; object-fit: cover; object-position: center;">
            </div>
        </div>
        index++;
    }
</div>
