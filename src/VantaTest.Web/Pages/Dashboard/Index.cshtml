@page
@model VantaTest.Web.Pages.Dashbord.IndexModel
@{
}
<div class="container-fluid p-4">
    <!-- Üst Başlık Alanı -->
    <header class="bg-white p-4 rounded-3 shadow-sm mb-4 text-center">
        <h1 class="h3 text-primary m-0"><i class="bi bi-grid-fill me-2"></i>Restoran Menü Yönetim Paneli</h1>
        <p class="text-muted mb-0">Yemekleri ekleyin, düzenleyin veya listeden kaldırın.</p>
    </header>

    <div class="row g-4">
        <!-- SOL SÜTUN: Ekleme/Düzenleme Formu -->
        <div class="col-lg-4 col-xl-3">
            <div class="card h-100">
                <div class="card-header bg-primary text-white fw-bold">
                    <i class="bi bi-plus-circle-dotted me-2"></i>Ürün Ekle / Düzenle
                </div>
                <div class="card-body">
                    <form id="productForm">
                        <!-- Görsel Yükleme Alanı -->
                        <div class="mb-4">
                            <label for="productImageInput" class="form-label fw-bold">Ürün Görseli</label>
                            <div class="image-upload-container" onclick="document.getElementById('productImageInput').click()">
                                <i class="bi bi-cloud-arrow-up fs-1 text-muted"></i>
                                <p class="text-muted mb-0 mt-2">Fotoğraf yüklemek için tıklayın</p>
                            </div>
                            <input type="file" class="form-control d-none" id="productImageInput" accept="image/*">
                            <img id="imagePreviewBox" class="image-preview shadow-sm" alt="Önizleme">
                        </div>

                        <!-- Kategori Seçimi -->
                        <div class="mb-3">
                            <label for="categorySelect" class="form-label fw-bold">Kategori</label>
                            <select class="form-select" id="categorySelect" required>
                                <option value="" selected disabled>Kategori Seçiniz...</option>
                                <option value="ana-yemek">Ana Yemekler</option>
                                <option value="ara-sicak">Ara Sıcaklar</option>
                                <option value="tatli">Tatlılar</option>
                                <option value="icecek">İçecekler</option>
                            </select>
                        </div>

                        <!-- İsim Alanı -->
                        <div class="mb-3">
                            <label for="nameInput" class="form-label fw-bold">Yemek Adı</label>
                            <input type="text" class="form-control" id="nameInput" placeholder="Örn: Adana Kebap" required>
                        </div>

                        <!-- Fiyat Alanı -->
                        <div class="mb-3">
                            <label for="priceInput" class="form-label fw-bold">Fiyat</label>
                            <div class="input-group">
                                <span class="input-group-text">₺</span>
                                <input type="number" class="form-control" id="priceInput" placeholder="0.00" step="0.01" required>
                            </div>
                        </div>

                        <!-- Açıklama Alanı -->
                        <div class="mb-3">
                            <label for="descriptionInput" class="form-label fw-bold">Açıklama</label>
                            <textarea class="form-control" id="descriptionInput" rows="3" placeholder="Yemek hakkında kısa bilgi..."></textarea>
                        </div>

                        <!-- Kaydet Butonu -->
                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-save2 me-2"></i>Kaydet
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- SAĞ SÜTUN: Yemek Listesi Tablosu -->
        <div class="col-lg-8 col-xl-9">
            <div class="card h-100">
                <div class="card-header bg-white fw-bold d-flex justify-content-between align-items-center py-3">
                    <span><i class="bi bi-list-ul me-2 text-primary"></i>Yemek Listesi</span>
                    <span class="badge bg-light text-dark border">Toplam: 3 Ürün</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover table-striped mb-0 align-middle">
                            <thead class="table-light sticky-top text-muted small text-uppercase">
                                <tr>
                                    <!-- scope="col" ifadeleri kaldırıldı -->
                                    <th class="ps-4">Görsel & İsim</th>
                                    <th>Kategori</th>
                                    <th>Fiyat</th>
                                    <th>Oluşturma Tarihi</th>
                                    <th>Güncelleme Tarihi</th>
                                    <th class="text-end pe-4">İşlemler</th>
                                </tr>
                            </thead>
                            <tbody id="foodTableBody">
                                <!-- Örnek Veri Satırı 1 -->
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            <img src="https://dummyimage.com/50x50/dee2e6/6c757d.jpg&text=IMG" class="rounded-circle me-3" alt="Yemek" width="50" height="50">
                                            <div>
                                                <h6 class="mb-0 fw-bold">Izgara Köfte</h6>
                                                <small class="text-muted d-block text-truncate" style="max-width: 150px;">Lezzetli ev yapımı köfte tabağı.</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td><span class="badge bg-success-subtle text-success-emphasis rounded-pill">Ana Yemek</span></td>
                                    <td class="fw-bold text-primary">₺240.00</td>
                                    <td><small class="text-muted">12.10.2023 14:30</small></td>
                                    <td><small class="text-muted">15.10.2023 09:15</small></td>
                                    <td class="text-end pe-4">
                                        <i class="bi bi-pencil-square text-primary fs-5 me-3 table-action-btn btn-edit" title="Düzenle"></i>
                                        <i class="bi bi-x-circle text-danger fs-5 table-action-btn btn-delete" title="Sil" onclick="deleteRow(this)"></i>
                                    </td>
                                </tr>
                                <!-- Örnek Veri Satırı 2 -->
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            <img src="https://dummyimage.com/50x50/dee2e6/6c757d.jpg&text=IMG" class="rounded-circle me-3" alt="Yemek" width="50" height="50">
                                            <div>
                                                <h6 class="mb-0 fw-bold">Mercimek Çorbası</h6>
                                                <small class="text-muted d-block text-truncate" style="max-width: 150px;">Sıcak başlangıç.</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td><span class="badge bg-warning-subtle text-warning-emphasis rounded-pill">Ara Sıcak</span></td>
                                    <td class="fw-bold text-primary">₺60.00</td>
                                    <td><small class="text-muted">10.10.2023 11:00</small></td>
                                    <td><small class="text-muted">-</small></td>
                                    <td class="text-end pe-4">
                                        <i class="bi bi-pencil-square text-primary fs-5 me-3 table-action-btn btn-edit" title="Düzenle"></i>
                                        <i class="bi bi-x-circle text-danger fs-5 table-action-btn btn-delete" title="Sil" onclick="deleteRow(this)"></i>
                                    </td>
                                </tr>
                                <!-- Örnek Veri Satırı 3 -->
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            <img src="https://dummyimage.com/50x50/dee2e6/6c757d.jpg&text=IMG" class="rounded-circle me-3" alt="Yemek" width="50" height="50">
                                            <div>
                                                <h6 class="mb-0 fw-bold">Künefe</h6>
                                                <small class="text-muted d-block text-truncate" style="max-width: 150px;">Peynirli sıcak tatlı.</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td><span class="badge bg-danger-subtle text-danger-emphasis rounded-pill">Tatlılar</span></td>
                                    <td class="fw-bold text-primary">₺180.00</td>
                                    <td><small class="text-muted">18.10.2023 16:45</small></td>
                                    <td><small class="text-muted">18.10.2023 17:00</small></td>
                                    <td class="text-end pe-4">
                                        <i class="bi bi-pencil-square text-primary fs-5 me-3 table-action-btn btn-edit" title="Düzenle"></i>
                                        <i class="bi bi-x-circle text-danger fs-5 table-action-btn btn-delete" title="Sil" onclick="deleteRow(this)"></i>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-footer bg-white py-3">
                    <nav aria-label="Tablo sayfalama">
                        <ul class="pagination justify-content-end mb-0">
                            <li class="page-item disabled">
                                <a class="page-link">Önceki</a>
                            </li>
                            <li class="page-item active"><a class="page-link" href="#">1</a></li>
                            <li class="page-item"><a class="page-link" href="#">2</a></li>
                            <li class="page-item">
                                <a class="page-link" href="#">Sonraki</a>
                            </li>
                        </ul>
                    </nav>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Başarı Bildirimi (Toast) -->
<div class="toast-container position-fixed bottom-0 end-0 p-3">
    <div id="successToast" class="toast align-items-center text-bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body">
                <i class="bi bi-check-circle-fill me-2"></i>İşlem başarıyla kaydedildi!
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Kapat"></button>
        </div>
    </div>
</div>
