@page
@model VantaTest.Web.Pages.Dashbord.Categories.IndexModel
@{
}
@section Styles {
    <abp-style src="/pages/dashboard/Categories/index.css" />
}
@section Scripts {
    <abp-script src="/pages/dashboard/Categories/index.js" />
}
<div class="container p-4">
    <header class="bg-white p-4 rounded-3 shadow-sm mb-4 d-flex justify-content-between align-items-center">
        <div>
            <h1 class="h3 text-primary m-0"><i class="bi bi-grid-fill me-2"></i>Menü Yönetim Paneli</h1>
            <p class="text-muted mb-0">Kategori listesini yönetin.</p>
        </div>
        <a asp-page="./Create" class="btn btn-primary">
            <i class="bi bi-plus-lg me-2"></i>Yeni Kategori Ekle
        </a>
    </header>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0 align-middle">
                    <thead class="table-light text-muted small text-uppercase">
                        <tr>
                            <th>İsim</th>
                            <th>Ana Kategori</th>
                            <th>Kayıt Tarihi</th>
                            <th class="text-end pe-4">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Categories)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div>
                                            <h6 class="mb-0 fw-bold">@item.Name</h6>
                                        </div>
                                    </div>
                                </td>
                                @foreach (var parent in Model.ParentCategories)
                                {
                                    if (item.ParentId == parent.Id)
                                    {
                                        <td><span class="badge bg-danger-subtle text-danger-emphasis rounded-pill">@parent.Name</span></td>
                                    }
                                }
                                <td><small class="text-muted">@item.CreationTime.ToString("dd.MM.yyyy")</small></td>
                                <td class="text-end pe-4">
                                    <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm me-2" title="Düzenle">
                                        <i class="bi bi-pencil-square"></i>
                                        Düzenle
                                    </a>

                                    <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" class="d-inline">
                                        <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('Bu yemeği silmek istediğinize emin misiniz?');">
                                            <i class="bi bi-trash"></i>
                                            Sil
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
