@page
@model VantaTest.Web.Pages.Dashboard.Categories.EditModel
@{
}
<div class="container p-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-warning text-dark fw-bold">
                    <i class="bi bi-pencil-square me-2"></i>Kategori Düzenle
                </div>
                <div class="card-body">
                    <form method="post">
                        <div class="mb-3">
                            <label for="categorySelect" class="form-label fw-bold">Kategori</label>
                            <select class="form-select" id="categorySelect" asp-for="Category.ParentId" required>
                                @foreach (var category in Model.ParentCategories)
                                {
                                    <option value="@category.Id">@category.Name</option>
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Category.Name" class="form-label fw-bold">Kategori Adı</label>
                            <input type="text" asp-for="Category.Name" class="form-control" required>
                        </div>
                        <div class="d-flex justify-content-between">
                            <a asp-page="./Index" class="btn btn-secondary">İptal</a>
                            <button type="submit" class="btn btn-warning">Güncelle</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>