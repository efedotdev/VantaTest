@page
@model VantaTest.Web.Pages.Dashboard.Categories.CreateModel
@{
}
@section styles {
  <abp-style src="/Pages/Dashboard/Categories/Create/create.css" />
}
@section scripts {
   <abp-script src="/Pages/Dashboard/Categories/Create/create.js" />
}
<div class="container p-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white fw-bold">
                    <i class="bi bi-plus-circle me-2"></i>Yeni Kategori Ekle
                </div>
                <div class="card-body">
                    <form method="post" enctype="multipart/form-data">

                       
                        <div class="mb-3">
                            <label for="categorySelect" class="form-label fw-bold">Kategori</label>
                            <select class="form-select" id="categorySelect" asp-for="Category.ParentId" required>
                                <option value="" selected disabled>Kategori Seçiniz...</option>
                                @foreach (var category in Model.ParentCategories)
                                {
                                    <option value="@category.Id">@category.Name</option>
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Category.Name" class="form-label fw-bold">Kategori Adı</label>
                            <input type="text" asp-for="Category.Name" class="form-control" placeholder="Örn: Et Yemekleri" required>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-page="./Index" class="btn btn-secondary">İptal</a>
                            <button type="submit" class="btn btn-primary">Kaydet</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>