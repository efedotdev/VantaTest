@page
@model VantaTest.Web.Pages.Dashboard.Customization.Sliders.EditModel
@{
}
@section styles {
    <abp-style src="/pages/dashboard/customization/Sliders/edit/index.css" />
}
@section scripts {
    <abp-script src="/pages/dashboard/customization/Sliders/edit/index.js" />
}
<div class="container p-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-warning text-dark fw-bold">
                    <i class="bi bi-pencil-square me-2"></i>Kaydıran Düzenle
                </div>
                <div class="card-body">
                    <form method="post" enctype="multipart/form-data">

                        <div class="mb-4">
                            <label for="sliderImageInput" class="form-label fw-bold">Kaydıran Görseli</label>

                            <div class="image-upload-container text-center" id="uploadContainer" onclick="document.getElementById('sliderImageInput').click()" style="cursor: pointer;">

                                <img id="imagePreviewBox" class="image-preview mb-2" src="@Model.Slider.ImagePath" alt="Mevcut Görsel" style="display: block; margin: 0 auto;">

                                <div id="uploadPlaceholder">
                                    <i class="bi bi-arrow-repeat fs-2 text-muted"></i>
                                    <p class="text-muted mb-0 mt-2">Mevcut resmi güncellemek veya değiştirmek için tıklayın</p>
                                </div>
                            </div>

                            <input type="file" name="UploadedImage" class="form-control d-none" id="sliderImageInput" accept="image/*">

                            <input type="hidden" asp-for="Slider.ImagePath" />
                        </div>
                        <div class="mb-3">
                            <label asp-for="Slider.Title" class="form-label fw-bold">Başlık</label>
                            <input type="text" asp-for="Slider.Title" class="form-control" required>
                        </div>
                        <div class="d-flex justify-content-between">
                            <a asp-page="./Index" class="btn btn-secondary">İptal</a>
                            <button type="submit" class="btn btn-warning">Güncelle</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>